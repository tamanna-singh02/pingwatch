// PingWatch — Phase 1 schema (auth + multi-tenancy)
// Later phases add Monitor, CheckResult, Incident, AlertChannel, etc.
// on top of this without touching what's here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  invites     Invite[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  mfaEnabled   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// Join table between User and Organization — this is what makes the
// platform multi-tenant: a user can belong to more than one org, each
// with its own role.
model Membership {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("memberships")
}

// Pending invitations to join an org — accepted invites become a Membership.
model Invite {
  id        String   @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  email     String
  role      Role     @default(VIEWER)
  token     String   @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())

  @@index([orgId])
  @@unique([orgId, email])
  @@map("invites")
}

// Stored so refresh tokens can be revoked (logout, password change,
// "log out of all devices") instead of relying on JWT expiry alone.
model RefreshToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// Minimal audit trail starting with auth events; every module added later
// (monitors, incidents, alerts) writes into this same table.
model AuditLog {
  id        String   @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  actorId   String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@map("audit_logs")
}
